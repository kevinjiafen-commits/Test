        local char = player.Character
        local hrp = char and find(char,"HumanoidRootPart")
        if not hrp then return end
        local realCF = hrp.CFrame
        local offset = getDesyncOffset()
        hrp.CFrame = CFrame.new(offset)
        RunService.RenderStepped:Wait()
        hrp.CFrame = realCF
    end)
end

local function stopCSync()
    if Void.csyncConnection then
        Void.csyncConnection:Disconnect()
        Void.csyncConnection = nil
    end
end

local function updateVoid(dt)
    if not Void.voidActive then return end
    local S = Void.settings
    if tick() - Void.lastSwitch < S.switchSpeed then return end
    Void.lastSwitch = tick()
    Void.currentVoidIndex = (Void.currentVoidIndex % #Void.deepVoidPositions) + 1
end

