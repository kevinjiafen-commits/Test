-- == 頁面 4: Emote V3 增強 ==
local EmotePage = Window:Page({ Name = "Emote V3 增強", Columns = 2 })

local EmoteTargetSection = EmotePage:Section({ Name = "目標玩家", Side = 1 })
local targetPlayerDropdown = EmoteTargetSection:Dropdown({
    Name = "選擇目標玩家", Flag = "Dropdown_TargetPlayer", Items = {player.Name}, Default = player.Name,
    Callback = function(Option)
        local name = Option
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name == name then targetPlayer = p; if isEmoteEnabled and currentEmoteConfig then stopCustomEmote(); task.wait(0.1); playCustomEmote(currentEmoteConfig.speed, currentEmoteConfig.style) end break end
        end
    end
})
task.spawn(function()
    while true do
        local names = {}
        for _, p in ipairs(Players:GetPlayers()) do table.insert(names, p.Name) end
        pcall(function() targetPlayerDropdown:SetOptions(names) end)
        task.wait(3)
    end
end)

local emoteDropdown = EmoteTargetSection:Dropdown({
    Name = "播放表情", Flag = "Dropdown_Emote", Items = {}, Default = nil,
    Callback = function(Option)
        if isEmoteEnabled and packDropdown then
            local packName = packDropdown:Get() -- 假设有Get方法，如果没有可以用变量
            if emotePacks[packName] then
                for _, e in ipairs(emotePacks[packName]) do
                    if e.name == Option then stopCustomEmote(); task.wait(0.1); playCustomEmote(e.speed, e.style) break end
                end
            end
        end
    end
})

EmotePage:Section({ Name = "表情選擇", Side = 2 })
local packNames = {}
for n,_ in pairs(emotePacks) do table.insert(packNames, n) end
local packDropdown = EmoteTargetSection:Dropdown({
    Name = "表情包 (Pack)", Flag = "Dropdown_EmotePack", Items = packNames, Default = "Cosmic Chaos",
    Callback = function(Option)
        if emotePacks[Option] then
            local names = {}
            for _, e in ipairs(emotePacks[Option]) do table.insert(names, e.name) end
            pcall(function() emoteDropdown:SetOptions(names) end)
        end
    end
})
local initialPack = "Cosmic Chaos"
if emotePacks[initialPack] then
    local initialEmotes = {}
    for _, e in ipairs(emotePacks[initialPack]) do table.insert(initialEmotes, e.name) end
    pcall(function() emoteDropdown:SetOptions(initialEmotes) end)
end

local isEmoteEnabled = false
local emoteEnableToggle = EmotePage:Section({ Name = "表情控制", Side = 1 }):Toggle({
    Name = "啟用表情動畫 (Enable Emote Animation)", Flag = "Toggle_EmoteEnabled", Default = false,
    Callback = function(Value)
        isEmoteEnabled = Value
        if Value then
            local packName = packDropdown:Get() or "Cosmic Chaos"
            local emoteName = emoteDropdown:Get()
            if emotePacks[packName] then
                for _, e in ipairs(emotePacks[packName]) do
                    if e.name == emoteName then stopCustomEmote(); task.wait(0.1); playCustomEmote(e.speed, e.style) break end
                end
            end
        else stopCustomEmote() end
    end
})

EmotePage:Section({ Name = "速度與控制", Side = 2 }):Slider({ Name = "速度倍率 (Speed Multiplier)", Flag = "Slider_EmoteSpeed", Min = 1, Max = 3000, Default = 1, Decimals = 0, Callback = function(Value) defaultSpeedFactor = Value end })
EmotePage:Section({ Name = "停止表情", Side = 2 }):Button():Add("停止表情 (Stop Emote)", function()
