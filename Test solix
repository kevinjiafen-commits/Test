local autoPulseVoidEnabled = false
local autoPulseInitialDelay = 0
local autoPulseVoidDuration = 5
local autoPulseRealDuration = 5
local autoPulseThread = nil

local function runAutoPulseV2()
    if autoPulseThread then return end
    autoPulseThread = task.spawn(function()
        if autoPulseInitialDelay > 0 then task.wait(autoPulseInitialDelay) end
        while autoPulseVoidEnabled do
            if not Void.settings.enable_void then startVoid(); Void.settings.enable_void = true; voidToggle:Set(true) end
            task.wait(autoPulseVoidDuration)
            if Void.settings.enable_void then stopVoid(); Void.settings.enable_void = false; voidToggle:Set(false) end
            task.wait(autoPulseRealDuration)
        end
    end)
end

local function stopAutoPulseV2()
    autoPulseVoidEnabled = false
    if autoPulseThread then task.cancel(autoPulseThread); autoPulseThread = nil end
end

