            local stretchX = 1 + math.abs(math.sin(timeElapsed * 3.1 + pieceSeed)) * 3
            local stretchY = 1 + math.abs(math.cos(timeElapsed * 4.2 + pieceSeed)) * 3
            local stretchZ = 1 + math.abs(math.sin(timeElapsed * 5.3 + pieceSeed)) * 3
            currentSize = currentSize * Vector3.new(stretchX, stretchY, stretchZ)
        end

        if isMeatballMode then
            local meatRadius = 1 + math.sin(timeElapsed * 5 + pieceSeed) * 0.5
            finalPosition = Vector3.new(math.sin(pieceSeed) * meatRadius, math.cos(pieceSeed * 1.5) * meatRadius, math.sin(pieceSeed * 2) * meatRadius)
            local throb = math.max(0.1, math.abs(math.sin(timeElapsed * 10 + pieceSeed)) * 3)
            currentSize = currentSize * throb
        end

        if isNoodleMode then
            local chaoticNoise = math.noise(pieceSeed, timeElapsed * 15, 0)
            local thicknessX = math.clamp(math.abs(math.sin(timeElapsed * 25 + pieceSeed) * 8) + chaoticNoise * 5, 0.01, 10)
            local thicknessY = math.clamp(math.abs(math.cos(timeElapsed * 18 + pieceSeed * 1.5) * 8) - chaoticNoise * 5, 0.01, 10)
            local length = info.realPart.Size.Magnitude * (25 + math.sin(timeElapsed * 15 + pieceSeed) * math.cos(timeElapsed * 9 + pieceSeed) * 20)
            currentSize = Vector3.new(thicknessX, thicknessY, length)
            local spiralRadius = 5 + chaoticNoise * 8
            finalPosition = finalPosition + Vector3.new(math.cos(timeElapsed * 20 + pieceSeed) * spiralRadius, math.sin(timeElapsed * 22 + pieceSeed) * spiralRadius, math.sin(timeElapsed * 14 + pieceSeed) * spiralRadius)
            rotX = rotX + math.sin(timeElapsed * 15 + pieceSeed) * 5
            rotY = rotY + math.cos(timeElapsed * 12 + pieceSeed) * 5
            rotZ = rotZ + chaoticNoise * 15
        end

        if isPaperMode then
            currentSize = Vector3.new(currentSize.X, currentSize.Y, 0.01)
            rotZ = rotZ + (timeElapsed * 50)
        end

        if isJitterMode then
            local glitchOffset = Vector3.new(math.random(-20, 20)/10, math.random(-20, 20)/10, math.random(-20, 20)/10)
            if math.random() > 0.9 then glitchOffset = glitchOffset * 5 end
            finalPosition = finalPosition + glitchOffset
        end

        if isGhostMode then
            local flicker = math.noise(timeElapsed * 30, pieceSeed, 0)
            if flicker > 0.2 then targetTransparency = 1
            elseif flicker < -0.2 then targetTransparency = 0.8 end
            info.emitter.Color = ColorSequence.new(Color3.new(0,0,0))
        end

        info.fakePart.Size = currentSize
        info.fakePart.Transparency = targetTransparency
        info.fakePart.CFrame = (rootCFrame * CFrame.new(finalPosition)) * CFrame.Angles(rotX, rotY, rotZ)
    end
end)

