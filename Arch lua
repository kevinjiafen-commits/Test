local function startAutoPulseVoid()
    if autoPulseVoidThread then return end
    autoPulseVoidThread = task.spawn(function()
        while autoPulseVoidEnabled do
            local currentState = Void.settings.enable_void
            if currentState then
                stopVoid()
                Void.settings.enable_void = false
                if Rayfield and Rayfield.Flags and Rayfield.Flags["Toggle_VoidEnabled"] then
                    Rayfield.Flags["Toggle_VoidEnabled"]:Set(false)
                end
            else
                startVoid()
                Void.settings.enable_void = true
                if Rayfield and Rayfield.Flags and Rayfield.Flags["Toggle_VoidEnabled"] then
                    Rayfield.Flags["Toggle_VoidEnabled"]:Set(true)
                end
            end
            task.wait(autoPulseVoidInterval)
        end
    end)
end

local function stopAutoPulseVoid()
    autoPulseVoidEnabled = false
    if autoPulseVoidThread then
        task.cancel(autoPulseVoidThread)
        autoPulseVoidThread = nil
    end
end

