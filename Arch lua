                if subChild:IsA("JointInstance") or subChild:IsA("Script") or subChild:IsA("LocalScript") or subChild:IsA("Constraint") or subChild:IsA("BodyMover") or subChild:IsA("Attachment") then
                    subChild:Destroy()
                end
            end
            fakePart.Name = "EmoteVisual_" .. child.Name
            fakePart.Anchored = true
            fakePart.CanCollide = false
            fakePart.CanQuery = false
            fakePart.Massless = true
            fakePart.CastShadow = false
            fakePart.Parent = fakePartsFolder
            
